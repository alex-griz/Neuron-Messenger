<Window x:Class="Neuron.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Neuron"
        mc:Ignorable="d"
        Title="Neuron - Вход" Height="600" Width="400" ResizeMode="CanMinimize">
    <Canvas>
        <Canvas.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF22002E"/>
                <GradientStop Color="#FF3B0150" Offset="1"/>
            </LinearGradientBrush>
        </Canvas.Background>
        <Label Content="Войдите или зарегистрируйтесь" Canvas.Left="24" Canvas.Top="83" FontFamily="Cascadia Code" FontSize="20" Foreground="White" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <TextBox x:Name="LoginBox" Canvas.Left="90" TextWrapping="Wrap" Text="Логин" Canvas.Top="150" Width="220" HorizontalAlignment="Left" Height="30" VerticalAlignment="Top" Background="#208C8C8C" Foreground="White" BorderBrush="{x:Null}" FontFamily="Cascadia Code" FontSize="20" RenderTransformOrigin="0.517,0.3"/>
        <PasswordBox x:Name="PasswordBox" Canvas.Left="90" Canvas.Top="200" Width="220" HorizontalAlignment="Center" VerticalAlignment="Top" Height="30" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" FontFamily="Cascadia Code" FontSize="20" Password="password" RenderTransformOrigin="0.56,0.394"/>
        <Button x:Name="LoginButton" Content="ВОЙТИ" Canvas.Left="124" Canvas.Top="344" HorizontalAlignment="Center" VerticalAlignment="Top" Height="35" Width="150" Background="#208C8C8C" BorderBrush="{x:Null}" FontFamily="Cascadia Code" FontSize="20" Foreground="White" Click="LoginButton_Click"/>
        <Button x:Name="RegistrationButton" Content="Регистрация" Canvas.Left="124" Canvas.Top="394" RenderTransformOrigin="2.165,0.728" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" FontFamily="Cascadia Code" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Top" Width="150" Click="RegistrationButton_Click" Height="35"/>
        <CheckBox x:Name="SaveLogin" Content="Сохранить вход" Canvas.Left="122" Canvas.Top="306" FontFamily="Cascadia Code" Width="154" Height="23" Background="#208C8C8C" BorderBrush="White" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="16"/>
        <TextBox x:Name="Security_key_box" Canvas.Left="90" TextWrapping="Wrap" Text="Security key" Canvas.Top="250" Width="220" Height="30" Background="#208C8C8C" Foreground="White" BorderBrush="{x:Null}" FontFamily="Cascadia Code" FontSize="20" RenderTransformOrigin="0.517,0.3" HorizontalAlignment="Center" VerticalAlignment="Top"/>

    </Canvas>
</Window>