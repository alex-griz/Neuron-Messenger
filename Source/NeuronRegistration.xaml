<Window x:Class="Neuron.NeuronRegistration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Neuron"
        mc:Ignorable="d"
        Title="Neuron - Регистрация" Height="600" Width="400" ResizeMode="CanMinimize">
    <Grid>
        <Canvas>
            <Canvas.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF22002E"/>
                    <GradientStop Color="#FF3B0150" Offset="1"/>
                </LinearGradientBrush>
            </Canvas.Background>
            <Label Content="Введите данные для" Canvas.Left="88" Canvas.Top="61" HorizontalAlignment="Center" VerticalAlignment="Top" Width="224" Foreground="White" FontFamily="Cascadia Code" FontSize="20" Height="30"/>
            <Label Content="своего аккаунта" Canvas.Left="107" Canvas.Top="85" HorizontalAlignment="Center" VerticalAlignment="Center" Width="186" Foreground="White" FontFamily="Cascadia Code" FontSize="20" Height="33"/>
            <TextBox x:Name="UsernameBox" Canvas.Left="90" TextWrapping="Wrap" Text="Юзернейм" Canvas.Top="150" Width="220" Height="30" HorizontalAlignment="Left" VerticalAlignment="Top" FontFamily="Cascadia Code" FontSize="20" Foreground="White" Background="#208C8C8C" BorderBrush="{x:Null}"/>
            <TextBox x:Name="NameBox" Canvas.Left="90" TextWrapping="Wrap" Text="Имя" Canvas.Top="200" Width="220" Height="30" FontFamily="Cascadia Code" FontSize="20" Foreground="White" Background="#208C8C8C" BorderBrush="{x:Null}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <PasswordBox x:Name="PasswordBox" Canvas.Left="90" Canvas.Top="250" Width="220" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" Height="30" FontSize="20" RenderTransformOrigin="0.104,-0.927" Password="Пароль" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Button Content="РЕГИСТРАЦИЯ" Canvas.Left="125" Canvas.Top="350" Width="150" Height="30" FontFamily="Cascadia Code" FontSize="20" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" Click="Button_Click"/>
        </Canvas>

    </Grid>
</Window>
