<Window x:Class="Neuron.NeuronMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Neuron"
        mc:Ignorable="d"
        Title="Neuron - Мессенджер" 
        Height="800" 
        Width="1400" 
        MinHeight="600"
        MinWidth="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button" x:Key="GlassButton">
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#50FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox" x:Key="GlassListBox">
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="15">
                            <ScrollViewer>
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="GlassTextBox">
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Label" x:Key="GlassLabel">
            <Setter Property="Background" Value="#20FFFFFF"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Label">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Expander" x:Key="GlassExpander">
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Bahnschrift Light Condensed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="10">
                            <StackPanel>
                                <ToggleButton x:Name="HeaderSite"
                                      Content="{TemplateBinding Header}"
                                      FontFamily="{TemplateBinding FontFamily}"
                                      FontSize="{TemplateBinding FontSize}"
                                      Foreground="{TemplateBinding Foreground}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="10,5"
                                      HorizontalAlignment="Stretch"
                                      Cursor="Hand"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <ContentPresenter x:Name="ExpandSite" 
                                          Visibility="Collapsed"
                                          Margin="10,5"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#208C8C8C"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Cascadia Code"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10">
                            <StackPanel IsItemsHost="True" Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Cascadia Code"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="5">
                            <ContentPresenter ContentSource="Header"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#50FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <DataTemplate x:Key="TextTemplate">
            <Border Background="#208C8C8C" CornerRadius="10" Margin="5,3" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Width="40" Height="40"
                    CornerRadius="20" Background="#208C8C8C" Margin="0,0,10,0">
                        <Image Source="{Binding SenderImagePath}" Stretch="UniformToFill"/>
                    </Border>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SenderName}"
                       FontWeight="Bold" FontSize="18"
                       Tag="{Binding SenderUsername}"
                       MouseLeftButtonDown="Nickname_Click"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding MessageText}" TextWrapping="Wrap"
                       FontSize="16" Foreground="White" Margin="0,5,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding Time}" FontSize="11" Foreground="#CCCCCC"
                       Margin="0,5,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="ImageTemplate">
            <Border Background="#208C8C8C" CornerRadius="10" Margin="5,3" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Width="40" Height="40"
                    CornerRadius="20" Background="#208C8C8C" Margin="0,0,10,0">
                        <Image Source="{Binding SenderImagePath}" Stretch="UniformToFill"/>
                    </Border>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SenderName}"
                       FontWeight="Bold" FontSize="18"
                       Tag="{Binding SenderUsername}"
                       MouseLeftButtonDown="Nickname_Click"/>

                    <Image Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                   Source="{Binding FilePath}" MaxWidth="400" MaxHeight="300" Stretch="Uniform"
                   Margin="0,5,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding Time}" FontSize="11" Foreground="#CCCCCC"
                       Margin="0,5,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="VideoTemplate">
            <Border Background="#208C8C8C" CornerRadius="10" Margin="5,3" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Width="40" Height="40"
                    CornerRadius="20" Background="#208C8C8C" Margin="0,0,10,0">
                        <Image Source="{Binding SenderImagePath}" Stretch="UniformToFill"/>
                    </Border>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SenderName}"
                       FontWeight="Bold" FontSize="18"
                       Tag="{Binding SenderUsername}"
                       MouseLeftButtonDown="Nickname_Click"/>

                    <MediaElement Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                          Source="{Binding FilePath}" LoadedBehavior="Manual"
                          Width="400" Height="300" Margin="0,5,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding Time}" FontSize="11" Foreground="#CCCCCC"
                       Margin="0,5,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="AudioTemplate">
            <Border Background="#208C8C8C" CornerRadius="10" Margin="5,3" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Width="40" Height="40"
                    CornerRadius="20" Background="#208C8C8C" Margin="0,0,10,0">
                        <Image Source="{Binding SenderImagePath}" Stretch="UniformToFill"/>
                    </Border>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SenderName}"
                       FontWeight="Bold" FontSize="18"
                       Tag="{Binding SenderUsername}"
                       MouseLeftButtonDown="Nickname_Click"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,5,0,0">
                        <TextBlock Foreground="#CCCCCC">
                    <Run Text="🎵 "/>
                    <Run Text="{Binding FileName}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Duration, StringFormat='Длительность: {0}'}"
                           FontSize="12" Foreground="#AAAAAA" Margin="0,2,0,0"/>
                        <Button Content="▶" Click="PlayAudio_Click" Tag="{Binding FilePath}"
                        Style="{StaticResource GlassButton}" Width="40" Height="30"
                        FontSize="16" Margin="0,2,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding Time}" FontSize="11" Foreground="#CCCCCC"
                       Margin="0,5,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="FileTemplate">
            <Border Background="#208C8C8C" CornerRadius="10" Margin="5,3" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Width="40" Height="40"
                    CornerRadius="20" Background="#208C8C8C" Margin="0,0,10,0">
                        <Image Source="{Binding SenderImagePath}" Stretch="UniformToFill"/>
                    </Border>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SenderName}"
                       FontWeight="Bold" FontSize="18"
                       Tag="{Binding SenderUsername}"
                       MouseLeftButtonDown="Nickname_Click"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                       Foreground="White" TextDecorations="Underline"
                       Text="{Binding FileName}"
                       MouseLeftButtonDown="OpenFile_Click"
                       Margin="0,5,0,0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding Time}" FontSize="11" Foreground="#CCCCCC"
                       Margin="0,5,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF22002E"/>
                <GradientStop Color="#FF3B0150" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="500"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Expander Grid.Row="0" Style="{StaticResource GlassExpander}"
                      Header="Настройки" Height="Auto"
                      FontFamily="Cascadia Code" FontSize="36" Foreground="White"
                      Margin="0,0,0,10" Background="#208C8C8C">
                <StackPanel>
                    <Button Foreground="White" FontFamily="Cascadia Code" FontSize="20" 
                            Content="Профиль" Background="Transparent" Height="30" 
                            BorderBrush="{x:Null}" Click="OpenProfileEditor" HorizontalAlignment="Left"/>
                    <Button Foreground="White" FontFamily="Cascadia Code" FontSize="20" 
                            Content="Интерфейс" Background="Transparent" Height="30" 
                            BorderBrush="{x:Null}" HorizontalAlignment="Left"/>
                    <Button Foreground="White" FontFamily="Cascadia Code" FontSize="20" 
                            Content="Выйти" Background="Transparent" Height="30" 
                            BorderBrush="{x:Null}" Click="LogOut" HorizontalAlignment="Left"/>
                </StackPanel>
            </Expander>

            <Expander Grid.Row="1" Style="{StaticResource GlassExpander}"
                      Header="Добавить" Height="Auto"
                      FontFamily="Cascadia Code" FontSize="36" Foreground="White"
                      Margin="0,0,0,10" Background="#208C8C8C">
                <StackPanel>
                    <Button Background="Transparent" Foreground="White" BorderBrush="{x:Null}" 
                            Content="Контакт" Height="30" FontFamily="Cascadia Code" FontSize="20" 
                            Click="Add_Contact" HorizontalAlignment="Left"/>
                    <Button Background="Transparent" BorderBrush="{x:Null}" Foreground="White" 
                            Content="Группа" Height="30" FontFamily="Cascadia Code" FontSize="20" 
                            Click="Add_Group" HorizontalAlignment="Left"/>
                </StackPanel>
            </Expander>

            <ListBox x:Name="ChatList" Grid.Row="2" Style="{StaticResource GlassListBox}"
                     Foreground="White" FontFamily="Cascadia Code" FontSize="36" 
                     SelectionMode="Single" ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                     Background="#208C8C8C">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding ButtonName}" Tag="{Binding ChatID}" Height="60" 
                                Background="Transparent" BorderBrush="{x:Null}" Foreground="White" 
                                FontFamily="Cascadia Code" FontSize="24" Click="SelectContact"
                                HorizontalAlignment="Stretch" Margin="5,3"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="HeadNameLabel" Grid.Column="0" Style="{StaticResource GlassLabel}"
                       Content="" Foreground="White" FontFamily="Cascadia Code" FontSize="36" 
                       Height="60" Background="#208C8C8C"/>
                <Button x:Name="MembersButton" Grid.Column="1" Style="{StaticResource GlassButton}"
                        Content="Свойства" Width="90" Height="40" Foreground="White" 
                        FontFamily="Cascadia Code" FontSize="18" Click="OpenChatFeatures"
                        Margin="5,0" Background="#208C8C8C"/>
                <Button x:Name="DeleteButton" Grid.Column="2" Style="{StaticResource GlassButton}"
                        Content="Удалить" Width="90" Height="40" Foreground="White" 
                        FontFamily="Cascadia Code" FontSize="18" Click="DeleteChat" Background="#208C8C8C"/>
            </Grid>

            <ListBox x:Name="MessagesField" Grid.Row="1" Style="{StaticResource GlassListBox}"
                     Foreground="White" ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Background="{x:Null}" FontFamily="Cascadia Code" FontSize="16">
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Ответить" />
                        <MenuItem Header="Удалить" Click="DeleteMessage"/>
                    </ContextMenu>
                </ListBox.ContextMenu>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}" ContentTemplate="{Binding Template}" Tag="{Binding Id}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="AttachButton" Grid.Column="0" Style="{StaticResource GlassButton}"
                        Content="📄" Width="60" Height="60" FontSize="28" Foreground="White"
                        Margin="0,0,10,0" Background="#208C8C8C" Click="AttachFile"/>
                <TextBox x:Name="MessageField" Grid.Column="1" Style="{StaticResource GlassTextBox}"
                         TextWrapping="Wrap" Text="Сообщение..." Foreground="White" 
                         FontFamily="Cascadia Code" FontSize="20" Height="60" UndoLimit="512"
                         VerticalAlignment="Center" Margin="0,0,10,0" Background="#208C8C8C"/>
                <Button x:Name="SendButton" Grid.Column="2" Style="{StaticResource GlassButton}"
                        Content="🢁" Height="60" Width="95" Foreground="White" FontSize="36" 
                        Click="SendMessage" Background="#208C8C8C"/>
            </Grid>
        </Grid>
    </Grid>
</Window>