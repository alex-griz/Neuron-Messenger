<Window x:Class="Neuron.ProfileView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Neuron"
        mc:Ignorable="d"
        Title="Neuron - ProfileView" Height="600" Width="400" ResizeMode="CanMinimize">
    <Canvas>
        <Canvas.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF22002E"/>
                <GradientStop Color="#FF3B0150" Offset="1"/>
            </LinearGradientBrush>
        </Canvas.Background>
        <TextBox x:Name="NameBox" Canvas.Left="100" TextWrapping="Wrap" Text="" Canvas.Top="240" Width="200" Height="30" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" FontFamily="Cascadia Code" FontSize="24"/>
        <TextBox x:Name="BioBox" Canvas.Left="100" TextWrapping="Wrap" Text="" Canvas.Top="300" Width="200" HorizontalAlignment="Center" Height="120" VerticalAlignment="Top" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" FontFamily="Cascadia Code" FontSize="20"/>
        <Button x:Name="SaveButton" Content="СОХРАНИТЬ" Canvas.Left="130" Canvas.Top="450" HorizontalAlignment="Center" VerticalAlignment="Top" Width="140" Height="35" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" FontFamily="Cascadia Code" FontSize="24" Click="SaveProfile"/>
        <TextBox x:Name="UsernameBox" Canvas.Left="100" TextWrapping="Wrap" Text="" Canvas.Top="275" Width="200" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" FontFamily="Cascadia Code" FontSize="18" Height="20"/>
        <Image x:Name="AvatarBox" Height="160" Canvas.Left="120" Canvas.Top="40" Width="160"/>
        <Button x:Name="ChangeAvatarButton" Content="изменить фото" Canvas.Left="135" Canvas.Top="210" Width="130" Height="25" Background="#208C8C8C" BorderBrush="{x:Null}" Foreground="White" FontFamily="Cascadia Code" Click="ChangeProfilePhoto" HorizontalAlignment="Center" VerticalAlignment="Top"/>
    </Canvas>
</Window>